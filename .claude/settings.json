{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_edits.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/offline_guard.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/dart_format.sh\"" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(flutter pub get)",
      "Bash(dart format:*)",
      "Bash(flutter analyze:*)",
      "Bash(dart analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter build apk:*)"
    ]
  }
}
